{
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "dialog:default",
    "dialog:allow-open",
    "fs:default",
    "fs:allow-read",
    "fs:allow-write",
    "fs:allow-exists",
    "fs:allow-mkdir",
    "os:default",
    "shell:default",
    "shell:allow-execute",
    {
      "identifier": "fs:scope",
      "allow": ["$APPCONFIG/**", "$HOME/**", "**"]
    }
  ]
}
